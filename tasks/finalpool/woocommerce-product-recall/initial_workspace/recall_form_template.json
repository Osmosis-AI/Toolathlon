{
  "form_title": "Product Recall Information Confirmation Form",
  "fields": [
    {
      "name": "Customer Name",
      "type": "text",
      "required": true
    },
    {
      "name": "Contact Email", 
      "type": "text",
      "required": true
    },
    {
      "name": "Contact Phone Number",
      "type": "text",
      "required": false
    },
    {
      "name": "Product Model",
      "type": "text", 
      "required": true
    },
    {
      "name": "Product ID",
      "type": "text",
      "required": true
    },
    {
      "name": "Order Number",
      "type": "text",
      "required": true
    },
    {
      "name": "Purchase Date",
      "type": "text",
      "required": true
    },
    {
      "name": "Current Product Status",
      "type": "choice",
      "required": false,
      "choices": ["Not Used", "In Normal Use", "Has Issues", "Discarded"]
    },
    {
      "name": "Return Preference",
      "type": "choice", 
      "required": false,
      "choices": ["Full Refund", "Product Replacement", "Store Credit"]
    },
    {
      "name": "Problem Description",
      "type": "text",
      "required": false
    },
    {
      "name": "Agreement to Terms of Processing",
      "type": "choice",
      "required": true,
      "choices": ["I agree to proceed according to the recall processing procedure"]
    }
  ]
}
